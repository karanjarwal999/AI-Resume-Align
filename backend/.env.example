# Comma-separated list of origins allowed by CORSMiddleware.
# In production, set this to your deployed frontend origin (e.g. https://app.example.com).
ALLOWED_ORIGINS=http://localhost:3000

# Google Gemini API key used by the LLM service.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace-me

# Gemini model name used for resume customization.
GEMINI_MODEL=gemini-2.5-flash

# Path to the Firebase Admin SDK service-account JSON (used only for
# verifying Firebase ID tokens, NOT for storage).
# Generate via Firebase console -> Project settings -> Service accounts.
# This file contains a private key -- never commit it.
FIREBASE_ADMIN_CREDENTIALS_PATH=firebase-admin.json

# MongoDB connection. Used to persist authenticated customize history.
# For local dev: mongodb://localhost:27017
# For Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_URI=
MONGO_DB_NAME=airesumealign
